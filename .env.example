# ESG Metrics Pipeline - Environment Configuration
# Copy this file to .env and fill in your API key

# =============================================================================
# LLM API Configuration
# =============================================================================

# Option 1: DeepSeek (Recommended)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
LLM_API_BASE=https://api.deepseek.com/v1/chat/completions
LLM_MODEL=deepseek-chat

# Option 2: DashScope/Qwen (Alternative)
# DASHSCOPE_API_KEY=your-dashscope-api-key-here
# LLM_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
# LLM_MODEL=qwen-max

# Generic API key (used as fallback)
# LLM_API_KEY=your-api-key-here

# =============================================================================
# Notes
# =============================================================================
# - Never commit your actual .env file to git
# - The pipeline checks for API keys in this order:
#   DEEPSEEK_API_KEY > LLM_API_KEY > QWEN_API_KEY > DASHSCOPE_API_KEY
